{
  "name": "auto-apply-frontend",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "clean:next": "node -e \"require('node:fs').rmSync('.next',{recursive:true,force:true});require('node:fs').rmSync('.turbo',{recursive:true,force:true})\"",
    "dev": "next dev",
    "dev:fresh": "npm run clean:next && next dev",
    "start:fresh": "npm run clean:next && next build && next start",
    "repair": "npm run clean:next && npm run build",
    "build": "next build",
    "start": "npm run start:fresh",
    "start:prod": "next start",
    "lint": "next lint",
    "test": "vitest run --configLoader native",
    "test:watch": "vitest --configLoader native"
  },
  "dependencies": {
    "@platejs/basic-nodes": "^52.3.10",
    "@platejs/link": "^52.3.17",
    "@platejs/math": "^52.3.10",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.57.0",
    "@tanstack/react-query": "^5.99.0",
    "@types/three": "^0.184.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "jspdf": "^4.2.1",
    "katex": "^0.16.45",
    "lucide-react": "^1.8.0",
    "mammoth": "^1.12.0",
    "next": "^15.0.0",
    "pdfjs-dist": "^5.6.205",
    "platejs": "^52.3.21",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^15.0.0",
    "react-resizable-panels": "^4.10.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.184.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.20",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
